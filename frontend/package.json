{
  "name": "health-dashboard-frontend",
  "private": true,
  "version": "0.74.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "desktop:dev": "electron .",
    "desktop:build:web": "cross-env VITE_CLIENT_MODE=desktop_app vite build --base=./",
    "desktop:prepare-seed": "..\\venv\\Scripts\\python.exe ..\\scripts\\prepare_packaging_seed.py",
    "desktop:check-secrets": "..\\venv\\Scripts\\python.exe ..\\scripts\\check_packaging_secrets.py",
    "desktop:build:backend": "npm run desktop:prepare-seed && ..\\venv\\Scripts\\python.exe -m PyInstaller ../backend.spec --clean --noconfirm --distpath backend_bin --workpath build/backend_py",
    "desktop:build:all": "npm run desktop:build:web && npm run desktop:build:backend",
    "desktop:pack": "npm run desktop:build:all && npm run desktop:check-secrets && electron-builder --dir",
    "desktop:dist": "npm run desktop:build:all && npm run desktop:check-secrets && electron-builder",
    "desktop:postinstall": "electron-builder install-app-deps",
    "test": "vitest run",
    "test:units": "vitest run src/utils/americanUnits.test.ts"
  },
  "dependencies": {
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@tanstack/react-query": "^5.62.8",
    "@types/qrcode": "^1.5.6",
    "axios": "^1.7.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.16.0",
    "plotly.js-dist-min": "^2.35.2",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-activity-calendar": "^3.2.0",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "react-plotly.js": "^2.6.0",
    "react-qr-barcode-scanner": "^2.1.25",
    "react-router-dom": "^6.28.0",
    "react-tooltip": "^6.0.4",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.15",
    "@types/plotly.js": "^2.33.4",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-plotly.js": "^2.6.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^37.0.2",
    "electron-builder": "^26.0.12",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "~5.6.3",
    "vite": "^6.0.3",
    "vitest": "^3.2.6",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.myhealthdashboard.desktop",
    "productName": "Forma",
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "asar": true,
    "directories": {
      "output": "release74"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend_bin/backend.exe",
        "to": "backend.exe"
      },
      {
        "from": "../.env.desktop.public",
        "to": ".env"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "include": "build/installer.nsh"
    }
  }
}
