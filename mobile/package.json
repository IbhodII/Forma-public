{
  "name": "HealthDashboardMobile",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "android:release": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/android-release.ps1",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "postinstall": "node scripts/patch-android-native.js",
    "bundle:check": "expo export:embed --eager --platform android --dev false",
    "eas:configure": "cross-env EAS_NO_VCS=1 npx eas-cli build:configure -p android",
    "eas:init": "cross-env EAS_NO_VCS=1 npx eas-cli init",
    "eas:preview": "cross-env EAS_NO_VCS=1 npx eas-cli build --platform android --profile preview",
    "eas:production": "cross-env EAS_NO_VCS=1 npx eas-cli build --platform android --profile production"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "@react-navigation/stack": "^6.4.1",
    "@tanstack/react-query": "^5.100.14",
    "axios": "^1.16.1",
    "expo": "~52.0.47",
    "expo-asset": "~11.0.5",
    "expo-auth-session": "~6.0.3",
    "expo-background-task": "~0.1.5",
    "expo-battery": "~9.0.2",
    "expo-clipboard": "~7.0.1",
    "expo-constants": "~17.0.8",
    "expo-crypto": "~14.0.2",
    "expo-font": "~13.0.4",
    "expo-haptics": "~14.0.1",
    "expo-modules-core": "~2.2.3",
    "expo-task-manager": "~12.0.6",
    "expo-web-browser": "~14.0.2",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-calendars": "^1.1314.0",
    "react-native-chart-kit": "^6.12.2",
    "react-native-document-picker": "^9.3.1",
    "react-native-fs": "^2.20.0",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-health-connect": "^3.5.3",
    "react-native-keychain": "^10.0.0",
    "react-native-paper": "^5.15.3",
    "react-native-permissions": "^5.5.1",
    "react-native-reanimated": "^3.16.7",
    "react-native-safe-area-context": "^4.11.0",
    "react-native-screens": "~3.34.0",
    "react-native-sqlite-storage": "^6.0.1",
    "react-native-svg": "^15.15.5",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-vector-icons": "^10.3.0",
    "react-native-vision-camera": "^4.7.3",
    "react-native-vision-camera-mlkit-plugin": "^0.1.41",
    "react-native-worklets-core": "^1.5.0",
    "react-native-zip-archive": "^8.0.1",
    "victory-native": "^36.6.8"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "15.0.1",
    "@react-native-community/cli-platform-android": "15.0.1",
    "@react-native-community/cli-platform-ios": "15.0.1",
    "@react-native/babel-preset": "0.76.9",
    "@react-native/eslint-config": "0.76.9",
    "@react-native/metro-config": "0.76.9",
    "@react-native/typescript-config": "0.76.9",
    "@types/react": "^18.2.6",
    "@types/react-native-vector-icons": "^6.4.18",
    "@types/react-test-renderer": "^18.0.0",
    "babel-jest": "^29.6.3",
    "babel-preset-expo": "~12.0.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "18.3.1",
    "typescript": "5.0.4"
  },
  "engines": {
    "node": ">=18"
  }
}
