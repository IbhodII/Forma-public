# Скопируйте в mobile/.env перед сборкой (EAS подхватывает env при build).

# URL FastAPI — дефолты при сборке APK (можно переопределить в приложении).
# Рекомендуется задать оба: приложение подключится к доступному.
# Локальная Wi‑Fi (start.ps1 -MobileLan или Forma → «API для телефона»):
EXPO_PUBLIC_API_BASE_URL_LOCAL=
# Tailscale (100.x.x.x, Tailscale включён на телефоне):
EXPO_PUBLIC_API_BASE_URL_TAILSCALE=
# Устаревший одиночный URL (если LOCAL/TAILSCALE пусты):
EXPO_PUBLIC_API_BASE_URL=
# Legacy alias (поддерживается в коде):
EXPO_PUBLIC_API_BASE=

# OAuth — нативный бэкап SQLite на Android (папка FormaBackups в облаке).

# Яндекс OAuth: https://oauth.yandex.ru/client/new
# Redirect URI: myhealthdashboard://oauth/yandex
EXPO_PUBLIC_YANDEX_CLIENT_ID=
EXPO_PUBLIC_YANDEX_REDIRECT_URI=myhealthdashboard://oauth/yandex

# Google Cloud Console → OAuth 2.0 Client ID (Web application)
# Redirect URI: myhealthdashboard://oauth/google
# Для Android также добавьте SHA-1 debug/release в OAuth client (Android).
EXPO_PUBLIC_GOOGLE_CLIENT_ID=

# Опционально: reversed client id как scheme (com.googleusercontent.apps.XXXX)
# EXPO_PUBLIC_GOOGLE_ANDROID_REDIRECT_SCHEME=com.googleusercontent.apps.YOUR_ID

EAS_NO_VCS=1
