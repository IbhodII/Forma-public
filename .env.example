# =============================================================================
# PUBLIC CONFIG — safe to reference in docs, mobile builds, and desktop public
# template (.env.desktop.public). client_id values are public OAuth identifiers.
# =============================================================================

# Polar AccessLink — https://admin.polaraccesslink.com
POLAR_CLIENT_ID=
POLAR_API_REDIRECT_URI=http://127.0.0.1:8000/api/polar/callback
# Legacy name (if POLAR_API_REDIRECT_URI unset):
POLAR_REDIRECT_URI=http://127.0.0.1:8000/api/polar/callback
# POLAR_SCOPE=accesslink.read_all

# Яндекс.Диск OAuth — https://oauth.yandex.ru/
# Callback URL = YANDEX_REDIRECT_URI (port 8000 dev, 8002 Forma packaged)
# Default: PKCE without client_secret (desktop + packaged). Legacy server flow:
# YANDEX_OAUTH_FLOW=confidential
YANDEX_CLIENT_ID=
YANDEX_REDIRECT_URI=http://127.0.0.1:8000/api/cloud/callback/yandex
# Forma packaged (backend.exe):
# YANDEX_REDIRECT_URI=http://127.0.0.1:8002/api/cloud/callback/yandex
# PUBLIC_API_BASE_URL=http://127.0.0.1:8002
# YANDEX_EXTRA_SCOPES=login:email login:info
# YANDEX_OAUTH_MODE=login
# YANDEX_SCOPES=cloud_api:disk.app_folder

# Google Drive OAuth — https://console.cloud.google.com/apis/credentials
# Default: PKCE without client_secret (desktop + packaged). Legacy web client:
# GOOGLE_OAUTH_FLOW=confidential
GOOGLE_CLIENT_ID=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/cloud/callback/google
# Forma packaged:
# GOOGLE_REDIRECT_URI=http://127.0.0.1:8002/api/cloud/callback/google

# Публичный base URL API (если redirect из .env не задан):
# PUBLIC_API_BASE_URL=http://127.0.0.1:8002

# URL фронтенда (для OAuth redirect, опционально)
# FRONTEND_URL=http://127.0.0.1:5173

# =============================================================================
# PRIVATE SECRETS — developer .env only; NEVER copy into installer or
# .env.desktop.public. See docs/PACKAGING_SECRETS.md
# =============================================================================

POLAR_CLIENT_SECRET=

YANDEX_CLIENT_SECRET=

GOOGLE_CLIENT_SECRET=

# Open Food Facts — отправка новых продуктов (private contributor account)
# https://world.openfoodfacts.org/cgi/user.pl
OFF_USER_ID=
OFF_PASSWORD=
