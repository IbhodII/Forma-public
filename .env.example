# Polar AccessLink — https://admin.polaraccesslink.com
# Скопируйте в .env и заполните значения:
#   copy .env.example .env

POLAR_CLIENT_ID=
POLAR_CLIENT_SECRET=

# Redirect URL в Polar Admin (и для OAuth из настроек приложения):
POLAR_API_REDIRECT_URI=http://127.0.0.1:8000/api/polar/callback
# Устаревшее имя (если POLAR_API_REDIRECT_URI не задано):
POLAR_REDIRECT_URI=http://127.0.0.1:8000/api/polar/callback

# Необязательно. Если на flow.polar.com «Ой, что-то пошло не так» — оставьте закомментированным.
# POLAR_SCOPE=accesslink.read_all

# Яндекс.Диск (OAuth) — https://oauth.yandex.ru/
# 1) Платформа: «Веб-сервисы»
# 2) Callback URL = YANDEX_REDIRECT_URI (порт как у API: 8000 или 8002 — см. .api-port / VITE_API_PORT)
# 3) «Доступ к данным» → Яндекс.Диск: чтение + запись (cloud_api:disk.read / .write)
#    Без этого будет unauthorized_client при входе.
# Redirect URI (порт подставьте свой — 8000 dev, 8002 Forma):
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI=http://127.0.0.1:8000/api/cloud/callback/yandex
# Forma packaged (backend.exe на 8002):
# YANDEX_REDIRECT_URI=http://127.0.0.1:8002/api/cloud/callback/yandex
# PUBLIC_API_BASE_URL=http://127.0.0.1:8002
# Для входа с телефона добавьте в oauth.yandex.ru тот же путь с IP ПК, например:
# http://192.168.31.210:8000/api/cloud/callback/yandex
# Только если в oauth.yandex.ru включён «Яндекс ID» (email), при правах Диска уже включённых:
# YANDEX_EXTRA_SCOPES=login:email login:info
# Если в приложении НЕТ прав Диска, только вход (без бэкапа на Диск):
# YANDEX_OAUTH_MODE=login
# Полная подмена scope (редко):
# YANDEX_SCOPES=cloud_api:disk.read cloud_api:disk.write

# Google Drive (OAuth) — https://console.cloud.google.com/apis/credentials
# Redirect URI dev: http://127.0.0.1:8000/api/cloud/callback/google
# Redirect URI Forma: http://127.0.0.1:8002/api/cloud/callback/google
# Google OAuth в режиме Testing — добавьте email в Test users
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/cloud/callback/google
# Forma packaged:
# GOOGLE_REDIRECT_URI=http://127.0.0.1:8002/api/cloud/callback/google

# Публичный base URL API (если redirect из .env не задан):
# PUBLIC_API_BASE_URL=http://127.0.0.1:8002

# URL фронтенда (для OAuth redirect, опционально)
# FRONTEND_URL=http://127.0.0.1:5173

# Open Food Facts — отправка новых продуктов (мобильный сканер)
# Аккаунт: https://world.openfoodfacts.org/cgi/user.pl
OFF_USER_ID=
OFF_PASSWORD=
